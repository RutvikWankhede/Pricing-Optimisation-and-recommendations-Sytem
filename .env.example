# .env.example
# Copy this file to .env and fill in the actual secret values.

# Database connection URL
DATABASE_URL=sqlite:///./pricing_ai.db

# JWT Settings
SECRET_KEY=your-very-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS origins (comma separated, e.g., https://example.com,https://app.example.com)
CORS_ORIGINS=

# Upload folder limits (in bytes)
MAX_IMAGE_SIZE=5242880  # 5 MB
MAX_DOCUMENT_SIZE=26214400  # 25 MB
